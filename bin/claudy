#!/usr/bin/env bash
#
# Usage: claudy [OPTIONS] [-- CLAUDE_ARGS...]
#
# Options:
#   --mcp-list              List available MCP servers in the current directory
#   --mcp-servers A,B,...   Launch claude with the specified MCP servers
#   -h, --help              Show this help
#
# Environment:
#   MCP_CONFIG_DIR          Directory to look for <server>.json files (default: current dir)
#
# Examples:
#   claudy --mcp-list
#   claudy --mcp-servers github,pagerduty
#   claudy --mcp-servers github -- --dangerously-skip-permissions

set -eu

BIN="$(basename "$0")"
MCP_DIR=~/projects/ai/mcp-servers

# Log variables and functions
RED='\033[0;31m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
BLUE='\033[0;34m'
NO_COLOR='\033[0m'

echo_stderr() {
  echo -e "$@" 1>&2
}

ok() {
  echo_stderr "${GREEN}OK${NO_COLOR}    $1"
}

info() {
  echo_stderr "${BLUE}INFO${NO_COLOR}  $1"
}

warn() {
  echo_stderr "${ORANGE}WARN${NO_COLOR}  $1"
}

error() {
  echo_stderr "${RED}ERROR${NO_COLOR} $1"
  exit 1
}

print_help() {
  sed -Ene '/#\s?Usage: '"$BIN $*"'/,/^([^#]|$)/{p; /^([^#]|$)/q}' "$0" | sed -e '$d; s/#\s\?//'
}

main() {
  local list_mode=false
  local servers=""
  local pass_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        print_help
        exit 0;;
      --mcp-list)
        list_mode=true;;
      --mcp-servers)
        servers="${2-}"
        [[ -z "$servers" ]] && error "$1 requires an argument"
        shift;;
      --mcp-servers=*)
        servers="${1#*=}";;
      --)
        shift
        break;;
      *)
        info "Forwarding option $1"
        pass_args+=("$1");;
    esac
    shift
  done

  pass_args+=("$@")

  # In list mode just list the available mcp servers and exit
  if "$list_mode"; then
    echo "Builtin MCP servers:"
    echo "  - chrome"
    echo "Available MCP servers in $MCP_DIR:"
    for f in "$MCP_DIR"/*.json; do
      [[ -f "$f" ]] && echo "  - $(basename "$f" .json)"
    done
    exit 0
  fi

  local mcp_servers=()
  local chrome=false
  if [[ -n "$servers" ]]; then
    # Read mcp server names from --mcp-servers argument comma-separated list
    IFS=',' read -ra server_list <<< "$servers"
    for server in "${server_list[@]}"; do
      server="${server// /}"

      # Special case for chrome since it's built-in
      if [[ "$server" == "chrome" ]]; then
        pass_args+=("--chrome")
        chrome=true
        continue
      fi

      local cfg="$MCP_DIR/$server.json"
      [[ ! -f "$cfg" ]] && error "no config for '$server' ($cfg)"
      mcp_servers+=("$cfg")
    done

    # Build claude --mcp-config argument
    local mcp_args=()
    [[ "${#mcp_servers[@]}" -gt 0 ]] && mcp_args+=("--mcp-config" "${mcp_servers[@]}")
  fi

  # Disable chrome if it wasn't explicitly included in the list of servers
  ! "$chrome" && pass_args+=("--no-chrome")

  set -x
  exec claude --strict-mcp-config "${mcp_args[@]}" "${pass_args[@]}"
}

main "$@"
