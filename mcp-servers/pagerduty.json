{
  "mcpServers": {
    "pagerduty": {
      "description": "Manage PagerDuty incidents, services, schedules, and on-call rotations.",
      "type": "stdio",
      "command": "uvx",
      "args": [
        "pagerduty-mcp"
      ],
      "env": {
        "PAGERDUTY_USER_API_KEY": "${TF_VAR_pagerduty_token}"
      }
    }
  }
}
