{
  "mcpServers": {
    "incident-io": {
      "description": "Manage incident.io incidents, actions, follow-ups, and post-mortems.",
      "command": "go",
      "args":[
        "run",
        "github.com/incident-io/incidentio-mcp-golang/cmd/mcp-server@latest"
      ],
      "env": {
        "INCIDENT_IO_API_KEY": "${INCIDENT_IO_API_KEY}"
      }
    }
  }
}
