{
  "mcpServers": {
    "giantswarm-search": {
      "description": "Search Giant Swarm documentation, intranet, and internal knowledge base.",
      "command": "go",
      "args": [
        "run",
        "github.com/giantswarm/search-mcp@latest",
        "serve"
      ],
      "env": {
        "OAUTH_ISSUER_URL": "https://dex.operations.awsprod.gigantic.io",
        "OAUTH_CLIENT_ID": "searchmcp"
      }
    }
  }
}
